# BorealOS shared configuration — EXAMPLE FILE.
#
# Copy this file to "borealos.env" in the same directory and edit the values:
#
#   cp config/borealos.env.example config/borealos.env
#
# The BorealOS scripts source config/borealos.env automatically when it exists.
# This .example file is never loaded by the scripts, so it is safe to commit.
# Keep your real borealos.env out of version control if it contains anything
# you would rather not share.

# Absolute path to the LineageOS/AOSP workspace.
#
# WARNING: a synced Android source tree is very large (tens of gigabytes), so
# choose a location with plenty of free disk space.
BOREALOS_WORKSPACE="${HOME}/borealos-lineageos"

# Target device codename. The first BorealOS target is the Google Pixel 8 Pro.
BOREALOS_DEVICE="husky"

# LineageOS 'repo' manifest URL.
LINEAGE_MANIFEST_URL="https://github.com/LineageOS/android.git"

# LineageOS branch to track.
#
# PLACEHOLDER: this is only an example value. Verify the correct branch for your
# device and the LineageOS version you intend to build before running any sync.
LINEAGE_BRANCH="lineage-21.0"
